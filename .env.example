# Copy to .env and fill in your values. Never commit .env to git.

# ── Supabase (required for real data) ──────────────────────────────────────────
# Find these in: Supabase dashboard → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-secret-key   # service_role, NOT anon key

# ── LM Studio (required for AI analysis) ──────────────────────────────────────
LMSTUDIO_BASE_URL=http://localhost:1234
LMSTUDIO_CHAT_MODEL=google/gemma-4-e2b
LMSTUDIO_EMBEDDING_MODEL=gpustack/bge-m3-GGUF

# ── Optional PDF export ───────────────────────────────────────────────────────
# Set only on servers where LibreOffice/soffice is installed and executable.
PDF_CONVERTER=
# PDF_CONVERTER_PATH=/usr/bin/soffice
